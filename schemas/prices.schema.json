{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["ticker", "price", "change", "currency", "asOf", "source", "isLive"],
    "additionalProperties": false,
    "properties": {
      "ticker": { "type": "string" },
      "price": { "type": "number" },
      "change": { "type": "number" },
      "currency": { "type": "string" },
      "asOf": { "type": "string" },
      "source": { "type": "string" },
      "isLive": { "type": "boolean" }
    }
  }
}
