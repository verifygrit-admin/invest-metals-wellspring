{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": {
    "type": "object",
    "required": ["near", "mid", "long"],
    "additionalProperties": false,
    "properties": {
      "near": { "$ref": "#/definitions/horizon" },
      "mid":  { "$ref": "#/definitions/horizon" },
      "long": { "$ref": "#/definitions/horizon" }
    }
  },
  "definitions": {
    "horizon": {
      "type": "object",
      "required": ["winners", "losers"],
      "additionalProperties": false,
      "properties": {
        "winners": { "$ref": "#/definitions/verdictList" },
        "losers":  { "$ref": "#/definitions/verdictList" }
      }
    },
    "verdictList": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["actor", "rationale"],
        "additionalProperties": false,
        "properties": {
          "actor": { "type": "string" },
          "rationale": { "type": "string" }
        }
      }
    }
  }
}
